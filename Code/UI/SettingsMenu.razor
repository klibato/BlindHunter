@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits PanelComponent

<root>
	@if ( IsOpen )
	{
		<div class="settings-overlay">
			<div class="settings-panel">
				<div class="settings-title">@Lang.Get("settings.title")</div>

				<div class="setting-row">
					<div class="setting-label">@Lang.Get("settings.master_volume")</div>
					<div class="preset-group">
						<div class="preset-button @(IsVolumePreset(0f) ? "active" : "")" @onclick=@(() => SetMasterVolume(0f))>@Lang.Get("settings.preset.mute")</div>
						<div class="preset-button @(IsVolumePreset(0.33f) ? "active" : "")" @onclick=@(() => SetMasterVolume(0.33f))>@Lang.Get("settings.preset.low")</div>
						<div class="preset-button @(IsVolumePreset(0.66f) ? "active" : "")" @onclick=@(() => SetMasterVolume(0.66f))>@Lang.Get("settings.preset.med")</div>
						<div class="preset-button @(IsVolumePreset(1f) ? "active" : "")" @onclick=@(() => SetMasterVolume(1f))>@Lang.Get("settings.preset.full")</div>
					</div>
				</div>

				<div class="setting-row">
					<div class="setting-label">@Lang.Get("settings.sfx_volume")</div>
					<div class="preset-group">
						<div class="preset-button @(IsSfxPreset(0f) ? "active" : "")" @onclick=@(() => SetSfxVolume(0f))>@Lang.Get("settings.preset.mute")</div>
						<div class="preset-button @(IsSfxPreset(0.33f) ? "active" : "")" @onclick=@(() => SetSfxVolume(0.33f))>@Lang.Get("settings.preset.low")</div>
						<div class="preset-button @(IsSfxPreset(0.66f) ? "active" : "")" @onclick=@(() => SetSfxVolume(0.66f))>@Lang.Get("settings.preset.med")</div>
						<div class="preset-button @(IsSfxPreset(1f) ? "active" : "")" @onclick=@(() => SetSfxVolume(1f))>@Lang.Get("settings.preset.full")</div>
					</div>
				</div>

				<div class="setting-row">
					<div class="setting-label">@Lang.Get("settings.music_volume")</div>
					<div class="preset-group">
						<div class="preset-button @(IsMusicPreset(0f) ? "active" : "")" @onclick=@(() => SetMusicVolume(0f))>@Lang.Get("settings.preset.mute")</div>
						<div class="preset-button @(IsMusicPreset(0.33f) ? "active" : "")" @onclick=@(() => SetMusicVolume(0.33f))>@Lang.Get("settings.preset.low")</div>
						<div class="preset-button @(IsMusicPreset(0.66f) ? "active" : "")" @onclick=@(() => SetMusicVolume(0.66f))>@Lang.Get("settings.preset.med")</div>
						<div class="preset-button @(IsMusicPreset(1f) ? "active" : "")" @onclick=@(() => SetMusicVolume(1f))>@Lang.Get("settings.preset.full")</div>
					</div>
				</div>

				<div class="setting-row">
					<div class="setting-label">@Lang.Get("settings.language")</div>
					<div class="preset-group">
						<div class="preset-button @(IsAppLanguage(AppLanguage.English) ? "active" : "")" @onclick=@(() => SetAppLanguage(AppLanguage.English))>@Lang.Get("settings.english")</div>
						<div class="preset-button @(IsAppLanguage(AppLanguage.French) ? "active" : "")" @onclick=@(() => SetAppLanguage(AppLanguage.French))>@Lang.Get("settings.french")</div>
					</div>
				</div>

				<div class="settings-footer">
					<div class="footer-note">@Lang.Get("settings.footer_note")</div>
				</div>

				<div class="back-button" @onclick=@OnBackClick>@Lang.Get("settings.back")</div>
			</div>
		</div>
	}
</root>

@code
{
	[Property] public bool IsOpen { get; set; } = false;

	public Action OnClose { get; set; }

	private bool IsVolumePreset( float val ) => MathF.Abs( GameSettings.MasterVolume - val ) < 0.05f;
	private bool IsSfxPreset( float val ) => MathF.Abs( GameSettings.SfxVolume - val ) < 0.05f;
	private bool IsMusicPreset( float val ) => MathF.Abs( GameSettings.MusicVolume - val ) < 0.05f;
	private bool IsAppLanguage( AppLanguage lang ) => GameSettings.AppLanguage == lang;

	private void SetMasterVolume( float val )
	{
		GameSettings.MasterVolume = val;
		Log.Info( $"MasterVolume set to {val:F2}" );
	}

	private void SetSfxVolume( float val )
	{
		GameSettings.SfxVolume = val;
		Log.Info( $"SfxVolume set to {val:F2}" );
	}

	private void SetMusicVolume( float val )
	{
		GameSettings.MusicVolume = val;
		Log.Info( $"MusicVolume set to {val:F2}" );
	}

	private void SetAppLanguage( AppLanguage lang )
	{
		GameSettings.AppLanguage = lang;
		Log.Info( $"AppLanguage set to {lang}" );
	}

	private void OnBackClick()
	{
		IsOpen = false;
		OnClose?.Invoke();
	}

	protected override void OnUpdate()
	{
		if ( IsOpen )
		{
			Mouse.Visible = true;
		}
	}

	protected override int BuildHash() => HashCode.Combine(
		IsOpen,
		GameSettings.MasterVolume,
		GameSettings.SfxVolume,
		GameSettings.MusicVolume,
		(int)Lang.Current
	);
}
