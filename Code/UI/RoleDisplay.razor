@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits PanelComponent

<root>
	@if (ShouldDisplay)
	{
		<div class="role-wrap">
			<div class="role-banner" style="color: @TextColor;">
				@RoleText
			</div>
			@if (HintLines.Count > 0)
			{
				<div class="role-hints">
					@foreach (var line in HintLines)
					{
						<div class="role-hint">@line</div>
					}
				</div>
			}
		</div>
	}
</root>

@code
{
	[Property] public PlayerSetup TargetPlayer { get; set; }
	[Property] public float DisplayDuration { get; set; } = 18f;

	private float DisplayUntil { get; set; }
	private PlayerRole _lastRole = PlayerRole.None;

	private bool ShouldDisplay => RealTime.Now < DisplayUntil && TargetPlayer != null && TargetPlayer.Role !=
PlayerRole.None && !TargetPlayer.IsProxy;

	private string RoleText => TargetPlayer?.Role switch
	{
		PlayerRole.Killer => Lang.Get("role.banner.killer"),
		PlayerRole.Survivor => Lang.Get("role.banner.survivor"),
		_ => ""
	};

	// Aligné sur le theme.scss : killer = blanc froid, survivor = blanc chaud
	private string TextColor => TargetPlayer?.Role switch
	{
		PlayerRole.Killer => "#c8d4e0",
		PlayerRole.Survivor => "#e0d4b8",
		_ => "#ffffff"
	};

	private List<string> HintLines
	{
		get
		{
			var list = new List<string>();
			if (TargetPlayer == null) return list;

			if (TargetPlayer.Role == PlayerRole.Killer)
			{
				list.Add(Lang.Get("tutorial.hint.killer.echo"));
				list.Add(Lang.Get("tutorial.hint.killer.attack"));
				list.Add(Lang.Get("tutorial.hint.killer.goal"));
			}
			else if (TargetPlayer.Role == PlayerRole.Survivor)
			{
				list.Add(Lang.Get("tutorial.hint.survivor.interact"));
				list.Add(Lang.Get("tutorial.hint.survivor.inventory"));
				list.Add(Lang.Get("tutorial.hint.survivor.goal"));
			}
			return list;
		}
	}

	protected override void OnUpdate()
	{
		if (TargetPlayer == null) return;

		// Trigger le banner à chaque transition None → Killer/Survivor
		// (au démarrage de la game, ou au retour de lobby)
		if (TargetPlayer.Role != _lastRole)
		{
			if (_lastRole == PlayerRole.None && TargetPlayer.Role != PlayerRole.None)
			{
				DisplayUntil = RealTime.Now + DisplayDuration;
			}
			_lastRole = TargetPlayer.Role;
		}
	}

	protected override int BuildHash() => HashCode.Combine(ShouldDisplay, RoleText, TextColor, (int)Lang.Current);
}
