@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits PanelComponent

<root>
	@if ( ShouldDisplay )
	{
		<div class="pause-overlay">
			<div class="pause-panel">
				<div class="pause-title">@Lang.Get("pause.title")</div>

				<div class="pause-buttons">
					<div class="pause-button" @onclick=@OnResumeClick>@Lang.Get("pause.resume")</div>
					<div class="pause-button" @onclick=@OnSettingsClick>@Lang.Get("pause.settings")</div>
					<div class="pause-button danger" @onclick=@OnDisconnectClick>@Lang.Get("pause.disconnect")</div>
				</div>
			</div>
		</div>
	}
</root>

@code
{
	private bool IsOpen { get; set; } = false;
	private bool _wasInGame = false;
	private SettingsMenu _settings;

	// Masque le pause overlay quand Settings est ouvert pour éviter le chevauchement
	// (les deux PanelComponent sur le même GameObject créent des stacking contexts séparés
	// donc le z-index CSS ne suffit pas à garantir l'ordre).
	private bool ShouldDisplay => IsOpen && !(_settings != null && _settings.IsOpen);

	protected override void OnStart()
	{
		// Auto-provision un SettingsMenu sur le même GameObject pour que les clients
		// puissent ouvrir leurs paramètres pendant la partie (la scène gameplay
		// n'en contient pas par défaut, contrairement au mainmenu).
		_settings = GetComponent<SettingsMenu>();
		if ( _settings == null )
		{
			_settings = GameObject.AddComponent<SettingsMenu>();
		}
		_settings.OnClose = ReopenAfterSettings;
	}

	protected override void OnUpdate()
	{
		if ( Input.Pressed( "PauseMenu" ) )
		{
			if ( _settings != null && _settings.IsOpen )
			{
				// Echap dans Settings → ferme Settings et revient au Pause
				_settings.IsOpen = false;
				IsOpen = true;
			}
			else
			{
				IsOpen = !IsOpen;
			}
		}

		// Auto-close when a new game round starts (transition lobby → in-game)
		bool isInGame = GameManager.Instance?.State == LobbyState.InGame;
		if ( isInGame && !_wasInGame )
		{
			IsOpen = false;
			if ( _settings != null ) _settings.IsOpen = false;
		}
		_wasInGame = isInGame;

		if ( IsOpen || (_settings != null && _settings.IsOpen) )
		{
			Mouse.Visible = true;
		}
	}

	private void OnResumeClick()
	{
		IsOpen = false;
	}

	private void OnSettingsClick()
	{
		if ( _settings == null ) return;
		IsOpen = false;
		_settings.IsOpen = true;
	}

	private void ReopenAfterSettings()
	{
		// Appelé par SettingsMenu quand l'utilisateur clique BACK
		IsOpen = true;
	}

	private void OnDisconnectClick()
	{
		if ( Networking.IsActive )
		{
			Game.Disconnect();
		}
		Game.ActiveScene.LoadFromFile( "scenes/mainmenu.scene" );
	}

	protected override int BuildHash() => HashCode.Combine( ShouldDisplay, (int)Lang.Current );
}
