@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits PanelComponent

<root>
	@if ( ShouldDisplay )
	{
		<div class="overlay">
			<div class="message" style="color: @MessageColor;">
				@MessageText
			</div>

			@if ( IsHost )
			{
				<div class="return-button" @onclick=@OnReturnClick>
					RETURN TO LOBBY
				</div>
			}
			else
			{
				<div class="waiting-text">
					Waiting for host...
				</div>
			}
		</div>
	}
</root>

@code
{
	[Property] public PlayerSetup TargetPlayer { get; set; }

	private bool IsHost => Networking.IsHost;

	private bool ShouldDisplay =>
		TargetPlayer != null
		&& !TargetPlayer.IsProxy
		&& GameStateManager.Instance != null
		&& GameStateManager.Instance.CurrentState != GameState.Playing;

	private string MessageText
	{
		get
		{
			if ( GameStateManager.Instance == null ) return "";
			if ( TargetPlayer == null ) return "";

			bool isKiller = TargetPlayer.Role == PlayerRole.Killer;
			bool survivorsWon = GameStateManager.Instance.CurrentState == GameState.SurvivorsWon;

			if ( survivorsWon )
			{
				return isKiller ? "THEY ESCAPED" : "YOU ESCAPED";
			}
			else
			{
				return isKiller ? "VICTORY" : "YOU DIED";
			}
		}
	}

	// Aligné sur le theme.scss : success vert sauge / danger rouge mat
	private string MessageColor
	{
		get
		{
			if ( GameStateManager.Instance == null ) return "#f0f0f0";
			if ( TargetPlayer == null ) return "#f0f0f0";

			bool isKiller = TargetPlayer.Role == PlayerRole.Killer;
			bool survivorsWon = GameStateManager.Instance.CurrentState == GameState.SurvivorsWon;

			if ( (survivorsWon && !isKiller) || (!survivorsWon && isKiller) )
				return "#6ba65d"; // $color-success
			else
				return "#cc1818"; // $color-danger
		}
	}

	private void OnReturnClick()
	{
		if ( !IsHost ) return;
		GameManager.Instance?.RequestReturnToLobby();
	}

	protected override int BuildHash() => HashCode.Combine(
		ShouldDisplay, MessageText, MessageColor, IsHost
	);
}