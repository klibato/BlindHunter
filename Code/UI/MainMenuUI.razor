@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits PanelComponent

<root>
    <div class="main-menu">
        <div class="dev-banner">STILL IN DEVELOPMENT</div>

        <div class="logo-container">
            <div class="logo-title">BLINDHUNTER</div>
            <div class="logo-subtitle">A horror echolocation experience</div>
        </div>

        <div class="button-container">
            <div class="menu-button play-button" @onclick=@OnPlayClick>
                PLAY
            </div>
            <div class="menu-button" @onclick=@OnSettingsClick>
                SETTINGS
            </div>
            <div class="menu-button" @onclick=@OnQuitClick>
                QUIT
            </div>
        </div>

        <div class="discord-button" @onclick=@OnDiscordClick>
            <div class="discord-icon">D</div>
            <div class="discord-label">
                @if (_showCopied)
                {
                    <span class="copied-feedback">LINK COPIED — PASTE IN BROWSER</span>
                }
                else
                {
                    <span>JOIN OUR DISCORD</span>
                    <span class="discord-url">discord.gg/QFFGHJF3jr</span>
                }
            </div>
        </div>

        <div class="footer">
            <div>BlindHunter v1 — by Klibato</div>
        </div>
    </div>
</root>

@code
{
    [Property] public string GameplaySceneFile { get; set; } = "scenes/gameplay.scene";
    [Property] public SettingsMenu SettingsPanel { get; set; }

    private const string DiscordUrl = "https://discord.gg/QFFGHJF3jr";
    private float _copiedFeedbackUntil = 0f;
    private bool _showCopied => RealTime.Now < _copiedFeedbackUntil;

    protected override void OnUpdate()
    {
        // Libère la souris pour qu'on puisse cliquer sur les boutons
        Mouse.Visible = true;
    }

    private void OnPlayClick()
    {
        // Charge la scène de jeu
        Game.ActiveScene.LoadFromFile(GameplaySceneFile);
    }

    private void OnSettingsClick()
    {
        if (SettingsPanel != null)
        {
            SettingsPanel.IsOpen = true;
        }
        else
        {
            Log.Warning("SettingsPanel ref not assigned in MainMenuUI inspector");
        }
    }

    private void OnQuitClick()
    {
        // Quit l'application
        Game.Close();
    }

    private void OnDiscordClick()
    {
        // Le sandbox s&box bloque Process.Start, donc on copie l'URL dans le clipboard
        // et on affiche un feedback. L'utilisateur colle dans son navigateur.
        Sandbox.UI.Clipboard.SetText(DiscordUrl);
        _copiedFeedbackUntil = RealTime.Now + 2.5f;
    }

    protected override int BuildHash() => HashCode.Combine(
        SettingsPanel?.IsOpen ?? false,
        _showCopied
    );
}
